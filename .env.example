# Smart Health Cabin local demo config

DATABASE_URL=postgres://smart_health_cabin:smart_health_cabin_dev@localhost:5432/smart_health_cabin
API_BASE_URL=http://localhost:3000
PUBLIC_REPORT_BASE_URL=http://localhost:3000/api/v1/reports
VITE_API_BASE_URL=http://localhost:3000
VOICE_AGENT_SERVER_URL=http://localhost:3004

# Sprint 5 provider mode
# mock keeps tests runnable. live is required for Sprint 5 acceptance evidence.
VOICE_PROVIDER_MODE=mock
VOICE_MODEL_MODE=mock
VOICE_MODEL_TIMEOUT_MS=30000
SPRINT5_REQUIRE_LIVE_PROVIDERS=true
ALLOW_MOCK_PROVIDERS=false
SPRINT5_REQUIRE_VLLM=true

# Avatar
VITE_AVATAR_IMAGE_SRC=/avatar/default-avatar.svg
STATIC_AVATAR_IMAGE_PATH=apps/kiosk-web/public/avatar/default-avatar.svg

# ASR: faster-whisper + Breeze-ASR-26 CTranslate2 int8
ASR_PROVIDER=faster_whisper_breeze_asr_26
ASR_ACCEPTANCE_PROVIDER=live
ASR_SERVICE_URL=http://localhost:8011
ASR_HEALTH_PATH=/healthz
ASR_TRANSCRIBE_PATH=/v1/asr/transcribe
ASR_MODEL=Breeze-ASR-26-CT2-int8
ASR_MODEL_PATH=/models/breeze-asr-26-ct2-int8
ASR_DEVICE=auto
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=zh
ASR_LANGUAGE_HINT=zh
ASR_REQUEST_TIMEOUT_MS=30000

# LLM: local Gemma 4 E4B through an OpenAI-compatible server such as vLLM
LLM_PROVIDER=vllm_openai_compatible
LLM_ACCEPTANCE_PROVIDER=live
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=gemma-4-e4b
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODELS_PATH=/models
LLM_MODEL=gemma-4-e4b
LLM_TIMEOUT_MS=15000
LLM_REQUEST_TIMEOUT_MS=30000
LLM_TEMPERATURE=0

# TTS: BreezyVoice default voice only
TTS_PROVIDER=breezyvoice_default
TTS_ACCEPTANCE_PROVIDER=live
TTS_SERVICE_URL=http://localhost:8012
TTS_HEALTH_PATH=/healthz
TTS_SYNTHESIZE_PATH=/v1/tts/synthesize
TTS_MODEL_PATH=/models/breezyvoice
TTS_VOICE=default
TTS_VOICE_ID=default
TTS_CACHE_DIR=.local/tts-cache
TTS_REQUEST_TIMEOUT_MS=30000

# Optional compatibility when using BreezyVoice's upstream OpenAI-compatible API directly.
# Keep this unset for the Sprint 4.5 sidecar path.
# BREEZYVOICE_BASE_URL=http://localhost:9003/v1
# BREEZYVOICE_MODEL=MediaTek-Research/BreezyVoice
# BREEZYVOICE_VOICE_ID=default

# Optional compatibility when the local Gemma 4 E4B is served by Ollama's
# OpenAI-compatible endpoint instead of vLLM. This is not a strict vLLM
# acceptance substitute unless the Sprint 5 evidence labels it as such.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e4b

# Redpanda outbox worker
REDPANDA_BROKERS=localhost:9092
REDPANDA_ADMIN_URL=http://localhost:9644
REDPANDA_CLIENT_ID=smart-health-cabin-outbox-worker
OUTBOX_WORKER_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=25
OUTBOX_MAX_ATTEMPTS=10
