# Smart Health Cabin local demo config

DATABASE_URL=postgres://smart_health_cabin:smart_health_cabin_dev@localhost:5432/smart_health_cabin
API_BASE_URL=http://localhost:3000
PUBLIC_REPORT_BASE_URL=http://localhost:3000/api/v1/reports
VITE_API_BASE_URL=http://localhost:3000
VOICE_AGENT_SERVER_URL=http://localhost:3004
VOICE_AGENT_PORT=3004

# Sprint 5 provider mode
# mock keeps tests runnable. live is required for Sprint 5 acceptance evidence.
VOICE_PROVIDER_MODE=mock
VOICE_MODEL_MODE=mock
VOICE_MODEL_TIMEOUT_MS=30000
SPRINT5_REQUIRE_LIVE_PROVIDERS=true
ALLOW_MOCK_PROVIDERS=false
SPRINT5_ALLOWED_LLM_PROVIDERS=ollama_native,ollama_openai_compatible,vllm_openai_compatible

# Voice entry activation gate
VOICE_ENTRY_MODE=wake_word_with_tap_fallback
WAKE_WORD_ENABLED=true
WAKE_WORD_MODE=mock
WAKE_WORD_PROVIDER=sherpa-onnx
WAKE_WORD_PHRASE=你好小慧
WAKE_WORD_SERVICE_URL=http://localhost:8013
WAKE_WORD_MODEL=sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20
WAKE_WORD_MODEL_PATH=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20
WAKE_WORD_INFERENCE_FRAMEWORK=sherpa-onnx
WAKE_WORD_THRESHOLD=0.65
WAKE_WORD_COOLDOWN_MS=2000
WAKE_WORD_SAMPLE_RATE=16000
WAKE_WORD_CHUNK_SIZE=1280
WAKE_WORD_DEVICE_INDEX=
WAKE_WORD_LOCAL_ONLY=true
VOICE_AUDIO_RETENTION=none
VOICE_ASR_CONFIDENCE_GATE_ENABLED=true
VOICE_MIN_ASR_CONFIDENCE=0.65
VOICE_MIN_OPTION_MARGIN=0.15
VOICE_ENABLE_DOMAIN_NORMALIZATION=true
VOICE_ENABLE_SEMANTIC_FRAME=true
VOICE_ENABLE_N_BEST_INTERFACE=true
VOICE_REQUIRE_CONFIRMATION_FOR_ASR=true
VOICE_SAFETY_SENSITIVE_CONFIRMATION=true
VOICE_DOMAIN_PACK_DIR=packages/voice-safety-core/domain-packs
VOICE_DEFAULT_DOMAIN_PACKS=phq9_zh_tw,smart_cabin_measurement,kiosk_faq
VOICE_ENABLE_ASR_HOTWORDS=true
VOICE_MAX_HOTWORDS_PER_REQUEST=80
SHERPA_ONNX_KWS_MODEL_DIR=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20
SHERPA_ONNX_KWS_ENCODER=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20/encoder-epoch-13-avg-2-chunk-16-left-64.onnx
SHERPA_ONNX_KWS_DECODER=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20/decoder-epoch-13-avg-2-chunk-16-left-64.onnx
SHERPA_ONNX_KWS_JOINER=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20/joiner-epoch-13-avg-2-chunk-16-left-64.onnx
SHERPA_ONNX_KWS_TOKENS=.local/models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20/tokens.txt
SHERPA_ONNX_KWS_KEYWORDS=.local/models/wakeword/ni-hao-xiao-hui.keywords.txt
SHERPA_ONNX_KWS_NUM_THREADS=2
SHERPA_ONNX_KWS_PROVIDER=cpu

# Vite-exposed kiosk voice-entry settings
VITE_WAKE_WORD_ENABLED=true
VITE_WAKE_WORD_SERVICE_URL=http://localhost:8013
VITE_VOICE_ENDPOINT_MODE=standard
VITE_VOICE_PREROLL_MS=300
VITE_VOICE_MIN_SPEECH_MS=250
VITE_VOICE_END_SILENCE_MS=900
VITE_VOICE_ELDER_END_SILENCE_MS=1500
VITE_VOICE_MAX_UTTERANCE_MS=20000
VITE_VOICE_ELDER_MAX_UTTERANCE_MS=30000

VOICE_ENDPOINT_MODE=standard
VOICE_ENDPOINT_ELDER_MODE_ENABLED=true
VOICE_PREROLL_MS=300
VOICE_END_SILENCE_MS=900
VOICE_ELDER_END_SILENCE_MS=1500
VOICE_MAX_UTTERANCE_MS=20000
VOICE_ELDER_MAX_UTTERANCE_MS=30000

# Avatar
VITE_AVATAR_IMAGE_SRC=/avatar/default-avatar.svg
STATIC_AVATAR_IMAGE_PATH=apps/kiosk-web/public/avatar/default-avatar.svg

# ASR: faster-whisper + Breeze-ASR-26 CTranslate2 int8
ASR_PROVIDER=faster_whisper_breeze_asr_26
ASR_ACCEPTANCE_PROVIDER=live
ASR_SERVICE_URL=http://localhost:8011
ASR_HEALTH_PATH=/healthz
ASR_TRANSCRIBE_PATH=/v1/asr/transcribe
ASR_MODEL=Breeze-ASR-26-CT2-int8
ASR_MODEL_PATH=/models/breeze-asr-26-ct2-int8
ASR_COMPUTE_BACKEND=gpu
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=int8
ASR_CPU_OFFLOAD=false
ASR_ALLOW_CPU_FALLBACK=false
ASR_LANGUAGE=zh
ASR_LANGUAGE_HINT=zh
ASR_REQUEST_TIMEOUT_MS=30000

# LLM: local Gemma 4 E4B through native Ollama for 1-5 sentence guidance.
LLM_PROVIDER=ollama_native
LLM_ACCEPTANCE_PROVIDER=live
LLM_COMPUTE_BACKEND=gpu
LLM_DEVICE=cuda
LLM_CPU_OFFLOAD=false
LLM_ALLOW_CPU_FALLBACK=false
LLM_BASE_URL=http://localhost:11434
LLM_MODELS_PATH=/models
LLM_MODEL=gemma4:e4b
LLM_TIMEOUT_MS=15000
LLM_REQUEST_TIMEOUT_MS=30000
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=80
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_THINK=false

# Optional vLLM alternative for local comparison.
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=gemma-4-e4b
VLLM_CPU_OFFLOAD_GB=0

# TTS: BreezyVoice default voice only
TTS_PROVIDER=breezyvoice_default
TTS_ACCEPTANCE_PROVIDER=live
TTS_COMPUTE_BACKEND=gpu
TTS_DEVICE=cuda
TTS_CPU_OFFLOAD=false
TTS_ALLOW_CPU_FALLBACK=false
TTS_SERVICE_URL=http://localhost:8012
TTS_HEALTH_PATH=/healthz
TTS_SYNTHESIZE_PATH=/v1/tts/synthesize
TTS_MODEL_PATH=/models/breezyvoice
TTS_VOICE=default
TTS_VOICE_ID=default
TTS_CACHE_DIR=.local/tts-cache
TTS_REQUEST_TIMEOUT_MS=30000

# Reranker: local Qwen3-Reranker-0.6B boundary for bounded retrieval/ranking
RERANKER_ENABLED=true
RERANKER_PROVIDER=qwen3_reranker_0_6b
RERANKER_SERVICE_URL=http://localhost:8014
RERANKER_HEALTH_PATH=/healthz
RERANKER_STATUS_PATH=/status
RERANKER_MODEL=Qwen3-Reranker-0.6B
RERANKER_MODEL_PATH=/models/qwen3-reranker-0.6b
RERANKER_COMPUTE_BACKEND=gpu
RERANKER_DEVICE=cuda
RERANKER_CPU_OFFLOAD=false
RERANKER_ALLOW_CPU_FALLBACK=false
RERANKER_MAX_CANDIDATES=50
RERANKER_TOP_K=5
RERANKER_TIMEOUT_MS=3000
RERANKER_MODE=mock
RERANKER_REQUIRED_FOR_LIVE_ACCEPTANCE=false

# Optional compatibility when using BreezyVoice's upstream OpenAI-compatible API directly.
# Keep this unset for the Sprint 4.5 sidecar path.
# BREEZYVOICE_BASE_URL=http://localhost:9003/v1
# BREEZYVOICE_MODEL=MediaTek-Research/BreezyVoice

# BreezyVoice streaming experiment runner
TTS_EXPERIMENT_RUN_ID=20260626_breezyvoice_streaming_matrix
TTS_EXPERIMENT_OUTPUT_DIR=experiments/20260626_breezyvoice_streaming_matrix
TTS_EXPERIMENT_DOMAIN_PROFILES=phq9_zh_tw,smart_cabin_measurement,kiosk_faq
TTS_EXPERIMENT_RANDOMIZE=true
TTS_EXPERIMENT_SAVE_EVENT_TRACE=true
TTS_EXPERIMENT_SAVE_CLIENT_METRICS=true
TTS_BENCHMARK_MODE=deterministic
# BREEZYVOICE_VOICE_ID=default
# BREEZYVOICE_GPU_DTYPE=float16

# Redpanda outbox worker
REDPANDA_BROKERS=localhost:9092
REDPANDA_ADMIN_URL=http://localhost:9644
REDPANDA_CLIENT_ID=smart-health-cabin-outbox-worker
OUTBOX_WORKER_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=25
OUTBOX_MAX_ATTEMPTS=10
